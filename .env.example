# ── Required ──────────────────────────────────────────────────────────────────

DATABASE_URL=postgres://postgres:postgres@localhost:5432/contract_agent?sslmode=disable

# API key for the active provider (only the matching key is required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── LLM provider ──────────────────────────────────────────────────────────────

LLM_PROVIDER=openai          # openai | anthropic (default: openai)
LLM_MODEL=gpt-4o-mini        # model name passed to the provider (default: gpt-4o-mini)
LLM_TEMPERATURE=0.2          # sampling temperature (default: 0.2)
LLM_MAX_RETRIES=3            # retry attempts on transient errors (default: 3)
LLM_RETRY_BASE_MS=500        # base delay in ms for exponential backoff (default: 500)

# ── Pipeline limits ───────────────────────────────────────────────────────────

ANALYSIS_CONCURRENCY=5           # clauses analyzed in parallel (default: 5)
SUMMARY_CLAUSE_TOKEN_BUDGET=200  # max tokens per clause gist in the summary prompt (default: 200)

# ── Per-run budget (across all clauses in one contract) ───────────────────────

RUN_MAX_TOKENS=500000        # total token cap for a full analysis run (default: 500000)
RUN_MAX_COST_USD=5.00        # total cost cap in USD (default: 5.00)
RUN_MAX_STEPS=200            # total agent step cap (default: 200)

# ── Per-agent budget (per clause) ─────────────────────────────────────────────

AGENT_MAX_TOKENS=50000       # token cap per clause agent (default: 50000)
AGENT_MAX_COST_USD=0.50      # cost cap per clause agent in USD (default: 0.50)

# ── Agent context window management ──────────────────────────────────────────

AGENT_CONTEXT_WINDOW=100000  # token limit before context compaction (default: 100000)
AGENT_COMPACT_RATIO=0.8      # fraction of context to compact when limit hit (default: 0.8)
AGENT_KEEP_RECENT=4          # number of recent messages to always keep (default: 4)

# ── Logging ───────────────────────────────────────────────────────────────────

LOG_LEVEL=info               # debug | info | warn | error (default: info)
